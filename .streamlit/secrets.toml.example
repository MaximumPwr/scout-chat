# .streamlit/secrets.toml.example
#
# Copy this file to .streamlit/secrets.toml and fill in your values.
#
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#
# NEVER commit secrets.toml — it is listed in .gitignore.
#
# Streamlit Cloud: paste these key-value pairs into the "Secrets" section
# of your app settings at share.streamlit.io (Advanced settings → Secrets).

# REQUIRED — get a free API key at https://console.anthropic.com
ANTHROPIC_API_KEY = "sk-ant-..."

# OPTIONAL — enables the in-chat feedback button (submits GitHub Issues).
# Create a fine-grained personal access token at https://github.com/settings/tokens
# with "Issues: Read and Write" permission on this repository.
# Without this key, the feedback feature shows a graceful error but the
# rest of the app works normally.
GITHUB_TOKEN = "ghp_..."
